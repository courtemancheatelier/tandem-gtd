# Database
DATABASE_URL="postgresql://user:password@localhost:5432/tandem_dev?schema=public"

# NextAuth
NEXTAUTH_URL="http://localhost:2000"
NEXTAUTH_SECRET="generate-a-random-string-at-least-32-characters"

# Node environment
NODE_ENV="development"

# AI Integration (optional)
# Server-wide Anthropic API key — shared with users if enabled in admin settings
# ANTHROPIC_API_KEY=sk-ant-...

# Encryption key for storing user API keys at rest (falls back to NEXTAUTH_SECRET)
# TANDEM_ENCRYPTION_KEY="generate-another-random-string"

# Override default AI model (default: claude-sonnet-4-20250514)
# TANDEM_AI_MODEL=claude-sonnet-4-20250514

# --- MCP Server ---------------------------------------------------------------

# MCP stdio transport (local — Claude Desktop / Claude Code)
# TANDEM_USER_ID=your-user-id

# MCP HTTP transport (deployed — claude.ai, ChatGPT, etc.)
# Comma-separated list of allowed CORS origins for the /api/mcp endpoint
# MCP_ALLOWED_ORIGINS=https://claude.ai,https://chatgpt.com

# OAuth — Google (https://console.cloud.google.com/apis/credentials)
# Redirect URI: {NEXTAUTH_URL}/api/auth/callback/google
# TODO: Before publishing, move Google OAuth from "Testing" to "Production" mode
#       in Google Cloud Console so all users can sign in (not just test users).
#       See: https://support.google.com/cloud/answer/15549049
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""

# OAuth — Apple (https://developer.apple.com — requires Developer Account)
# Redirect URI: {NEXTAUTH_URL}/api/auth/callback/apple
# APPLE_ID=""
# APPLE_SECRET=""

# OAuth — GitHub (https://github.com/settings/developers)
# Redirect URI: {NEXTAUTH_URL}/api/auth/callback/github
# GITHUB_CLIENT_ID=""
# GITHUB_CLIENT_SECRET=""

# OAuth — Microsoft / Entra ID (https://portal.azure.com → App registrations)
# Redirect URI: {NEXTAUTH_URL}/api/auth/callback/azure-ad
# MICROSOFT_ENTRA_ID_CLIENT_ID=""
# MICROSOFT_ENTRA_ID_CLIENT_SECRET=""
# MICROSOFT_ENTRA_ID_TENANT_ID="common"

# --- Web Push Notifications --------------------------------------------------

# VAPID keys (generate with: npx tsx scripts/generate-vapid-keys.ts)
# VAPID_PUBLIC_KEY=""
# VAPID_PRIVATE_KEY=""
# VAPID_SUBJECT="mailto:admin@your-domain.com"
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=""  # Same value as VAPID_PUBLIC_KEY

# Cron endpoint auth (generate a random string, e.g.: openssl rand -hex 32)
# CRON_SECRET=""

# --- Disaster Recovery --------------------------------------------------------

# Encryption passphrase for all backups (CRITICAL: store this off-server)
# Auto-generated by setup-local.sh if empty.
# BACKUP_PASSPHRASE=

# Backup schedule (cron expressions, server local time)
# BACKUP_SCHEDULE_DAILY="0 2 * * *"
# BACKUP_SCHEDULE_WEEKLY="0 3 * * 0"
# BACKUP_SCHEDULE_VERIFY="30 4 * * 0"
# BACKUP_SCHEDULE_WAL_BASE="0 4 * * 0"

# Retention
# BACKUP_RETAIN_DAILY=30
# BACKUP_RETAIN_WEEKLY=12
# BACKUP_RETAIN_WAL_DAYS=14

# WAL archiving — point-in-time recovery (requires PostgreSQL restart to enable)
# BACKUP_WAL_ENABLED=false

# PostgreSQL connection (used by backup scripts)
# BACKUP_PG_USER=tandem
# BACKUP_PG_DB=tandem
# BACKUP_PG_HOST=localhost
# BACKUP_PG_PORT=5432

# --- Off-Site Replication (configure one or more) -----------------------------

# Method A: rsync/scp
# BACKUP_RSYNC_ENABLED=false
# BACKUP_RSYNC_TARGET=user@backup-server:/backups/tandem
# BACKUP_RSYNC_SSH_KEY=~/.ssh/id_tandem_backup
# BACKUP_RSYNC_BANDWIDTH_LIMIT=0

# Method B: S3-compatible storage
# BACKUP_S3_ENABLED=false
# BACKUP_S3_BUCKET=tandem-backups
# BACKUP_S3_ENDPOINT=https://s3.us-west-000.backblazeb2.com
# BACKUP_S3_ACCESS_KEY=
# BACKUP_S3_SECRET_KEY=
# BACKUP_S3_REGION=us-west-000

# Method C: rclone
# BACKUP_RCLONE_ENABLED=false
# BACKUP_RCLONE_REMOTE=gdrive:tandem-backups
# BACKUP_RCLONE_BANDWIDTH_LIMIT=0

# --- Version Suffix -----------------------------------------------------------
# Set to "beta" on beta/alpha servers, leave empty for production
# NEXT_PUBLIC_VERSION_SUFFIX="beta"

# --- GitHub URL ---------------------------------------------------------------
# Public GitHub repo URL (used in landing page links)
# NEXT_PUBLIC_GITHUB_URL="https://github.com/courtemancheatelier/tandem-gtd"

# --- Legal / Operator Identity ------------------------------------------------
# OPERATOR_LEGAL_EMAIL="privacy@tandemgtd.com"
# OPERATOR_JURISDICTION="Massachusetts, United States"

# --- Notifications (optional) ------------------------------------------------
# BACKUP_NOTIFY_ON_FAILURE=false
# BACKUP_NOTIFY_WEBHOOK=
# BACKUP_NOTIFY_EMAIL=
