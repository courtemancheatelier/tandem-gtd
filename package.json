{
  "name": "tandem-gtd",
  "version": "1.9.1",
  "private": true,
  "scripts": {
    "dev": "next dev -p 2000",
    "build": "next build && cp -r .next/static .next/standalone/.next/static && cp -r public .next/standalone/public",
    "start": "PORT=2000 node .next/standalone/server.js",
    "lint": "next lint",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:seed": "ts-node --compiler-options {\"module\":\"CommonJS\"} prisma/seed.ts",
    "db:reset": "prisma migrate reset",
    "seed:help": "npx tsx prisma/seed-help.ts",
    "seed:templates": "npx tsx prisma/seed-templates.ts",
    "generate:openapi": "npx tsx src/lib/api/openapi/generator.ts"
  },
