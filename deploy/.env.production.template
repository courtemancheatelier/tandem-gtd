# =============================================================================
# Tandem GTD — Production Environment Template
# =============================================================================
# Used by scripts/setup-vps.sh to generate /opt/tandem/.env
# Placeholders (GENERATED_*) are replaced automatically during setup.
# =============================================================================

# --- Core -------------------------------------------------------------------
NODE_ENV="production"

# --- Database ----------------------------------------------------------------
DATABASE_URL="postgresql://tandem:GENERATED_DB_PASSWORD@localhost:5432/tandem?schema=public"

# --- NextAuth ----------------------------------------------------------------
NEXTAUTH_URL="https://GENERATED_DOMAIN"
NEXTAUTH_SECRET="GENERATED_NEXTAUTH_SECRET"

# --- Encryption --------------------------------------------------------------
# 32-byte hex key for encrypting user API keys at rest
TANDEM_ENCRYPTION_KEY="GENERATED_ENCRYPTION_KEY"

# --- MCP HTTP Transport ------------------------------------------------------
MCP_ALLOWED_ORIGINS="https://claude.ai,https://chatgpt.com"

# --- AI Integration (optional) -----------------------------------------------
# Server-wide Anthropic API key — shared with users if enabled in admin settings
# ANTHROPIC_API_KEY=sk-ant-...

# Override default AI model (default: claude-sonnet-4-20250514)
# TANDEM_AI_MODEL=claude-sonnet-4-20250514

# --- OAuth (optional) -------------------------------------------------------
# Google (https://console.cloud.google.com/apis/credentials)
# Redirect URI: ${NEXTAUTH_URL}/api/auth/callback/google
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""

# --- Disaster Recovery -------------------------------------------------------
BACKUP_PASSPHRASE="GENERATED_BACKUP_PASSPHRASE"
BACKUP_RETAIN_DAILY=30
BACKUP_RETAIN_WEEKLY=12
BACKUP_RETAIN_WAL_DAYS=14
BACKUP_WAL_ENABLED=false
BACKUP_PG_USER=tandem
BACKUP_PG_DB=tandem
BACKUP_PG_HOST=localhost
BACKUP_PG_PORT=5432

# --- Off-Site Replication (configure manually after setup) -------------------
# BACKUP_RSYNC_ENABLED=false
# BACKUP_RSYNC_TARGET=user@backup-server:/backups/tandem
# BACKUP_RSYNC_SSH_KEY=~/.ssh/id_tandem_backup
# BACKUP_S3_ENABLED=false
# BACKUP_S3_BUCKET=tandem-backups
# BACKUP_S3_ENDPOINT=https://s3.us-west-000.backblazeb2.com
# BACKUP_S3_ACCESS_KEY=
# BACKUP_S3_SECRET_KEY=
# BACKUP_S3_REGION=us-west-000
