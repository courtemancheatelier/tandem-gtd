# =============================================================================
# Tandem GTD — Environment Variables (Docker deployment)
# =============================================================================
# Copy this file to .env and update the values below.
# Run `./deploy/scripts/setup.sh` from the repo root to auto-generate secrets.
# =============================================================================

# --- PostgreSQL ---------------------------------------------------------------
POSTGRES_USER=tandem
POSTGRES_PASSWORD=change-me-to-a-strong-password
POSTGRES_DB=tandem

# --- Database URL (constructed from the values above) -------------------------
DATABASE_URL=postgresql://tandem:change-me-to-a-strong-password@db:5432/tandem

# --- NextAuth -----------------------------------------------------------------
NEXTAUTH_SECRET=change-me
NEXTAUTH_URL=https://your-domain.com

# --- Encryption ---------------------------------------------------------------
# 32-byte hex key used to encrypt user API keys at rest
TANDEM_ENCRYPTION_KEY=generate-a-32-byte-hex-key

# --- AI Integration (optional) -----------------------------------------------
# Server-wide Anthropic API key — shared with users if enabled in admin settings
# ANTHROPIC_API_KEY=sk-ant-...

# Override the default AI model (default: claude-sonnet-4-20250514)
# TANDEM_AI_MODEL=claude-sonnet-4-20250514

# --- OAuth Providers (optional) ----------------------------------------------
# Set up your own OAuth apps — each provider is optional.
# Redirect URI for all providers: {NEXTAUTH_URL}/api/auth/callback/{provider}
#
# Google: https://console.cloud.google.com/apis/credentials
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
#
# GitHub: https://github.com/settings/developers
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
#
# Microsoft: https://portal.azure.com → App registrations
# MICROSOFT_ENTRA_ID_CLIENT_ID=
# MICROSOFT_ENTRA_ID_CLIENT_SECRET=
# MICROSOFT_ENTRA_ID_TENANT_ID=common
#
# Apple: https://developer.apple.com (requires paid Developer Account)
# APPLE_ID=
# APPLE_SECRET=

# --- Push Notifications (optional) ------------------------------------------
# Generate with: npx web-push generate-vapid-keys
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=

# --- GitHub URL ---------------------------------------------------------------
# Public GitHub repo URL (used in landing page links)
# NEXT_PUBLIC_GITHUB_URL="https://github.com/courtemancheatelier/tandem-gtd"
